# ════════════════════════════════════════════════════════════════
# config/credentials.env.example — copy this to config/credentials.env
# ════════════════════════════════════════════════════════════════
# The real config/credentials.env is gitignored (never commit real secrets).
# This example is safe to commit because SauceDemo's test accounts are
# PUBLIC, intentionally published QA-practice credentials
# (https://www.saucedemo.com) — not a real secret leak.
#
# LOCAL_HTTP_USER / LOCAL_HTTP_PASS are consumed by ConfigLoader.ts for
# HTTP Basic Auth when TEST_ENV=local. SauceDemo does not sit behind HTTP
# Basic Auth, so these are left blank; default_env in project.yaml is set
# to "test" so this code path is not exercised in the demo.
LOCAL_HTTP_USER=
LOCAL_HTTP_PASS=""

# ── SauceDemo public test accounts (for reference / DATA sheet) ──
# Standard user — used for the positive login test case (TC-LOGIN-001, TC-CART-001)
SAUCEDEMO_STANDARD_USER=standard_user
SAUCEDEMO_STANDARD_PASSWORD=secret_sauce

# Locked-out user — used for the negative login test case (TC-LOGIN-002)
SAUCEDEMO_LOCKED_OUT_USER=locked_out_user
SAUCEDEMO_LOCKED_OUT_PASSWORD=secret_sauce
