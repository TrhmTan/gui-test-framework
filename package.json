{
  "name": "unified-gui-testing-tool",
  "version": "1.0.0",
  "description": "Unified GUI Testing Tool (Excel & Config Driven + AI assisted)",
  "main": "dist/index.js",
  "scripts": {
    "test": "npx ts-node scripts/run-test.ts",
    "run:all": "npx ts-node scripts/run-all.ts",
    "init:module": "npx ts-node scripts/init-module.ts",
    "create:common": "npx ts-node scripts/create-common-suite.ts",
    "create:l2-suite": "npx ts-node scripts/create-level2-suite.ts",
